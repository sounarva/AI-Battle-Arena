{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "target": "ES2020",

    "lib": ["ES2020"],
    "types": ["node"],

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "strict": true,
    "skipLibCheck": true,

    "sourceMap": true
  },
  "include": ["src", "server.ts"],
  "exclude": ["node_modules"]
}